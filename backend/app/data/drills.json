  "signal_definitions": {
    "high_left_miss_pct": "Shots with offline < 0 / total kept shots > 0.55",
    "high_right_miss_pct": "Shots with offline > 0 / total kept shots > 0.55",
    "good_smash": "Smash factor > 1.35",
    "low_smash": "Smash factor < 1.30 on irons",
    "face_to_path_negative": "Face-to-path angle < -2 degrees",
    "face_to_target_positive": "Face-to-target angle > 2 degrees",
    "path_out_to_in": "Club path < -3 degrees",
    "face_closed": "Face angle < -2 degrees at impact",
    "high_offline_std": "Offline standard deviation > 25 yards",
    "no_dominant_miss_direction": "Neither left nor right miss exceeds 60%",
    "club_path_out_to_in_gt5": "Club path < -5 degrees",
    "left_start_line": "Launch direction < -2 degrees consistently",
    "high_spin_axis_right": "Spin axis > 10 degrees (fade/slice spin)",
    "club_path_in_to_out_gt6": "Club path > 6 degrees",
    "high_right_start_line": "Launch direction > 3 degrees consistently",
    "low_peak_height": "Apex height below expected for club",
    "low_spin": "Spin rate below expected for club",
    "high_launch_angle": "Launch angle > 24 degrees on 7i equivalent",
    "carry_below_expected": "Carry distance significantly below expected for ball speed",
    "ball_speed_std_gt8": "Ball speed standard deviation > 8 mph for same club",
    "low_launch": "Launch angle < 12 degrees on 7i equivalent",
    "high_spin_compensating": "Spin rate > 6500 rpm paired with low launch",
    "high_launch": "Launch angle > 22 degrees on 7i",
    "high_spin": "Spin rate > 7000 rpm on 7i",
    "balloon_shots": "High apex with short carry relative to ball speed",
    "excessive_backspin": "Backspin > 7000 rpm on 7i",
    "steep_attack_angle": "Attack angle steeper than -6 degrees",
    "low_ball_speed_for_club": "Ball speed < 100 mph on 7i or < 140 mph driver",
    "decent_club_speed": "Club speed in normal range for the player",
    "spin_axis_right": "Spin axis tilted right (fade/slice tendency)",
    "offline_std_gt20": "Offline standard deviation > 20 yards",
    "carry_std_gt15": "Carry standard deviation > 15 yards",
    "no_improvement_3_sessions": "No measurable improvement across last 3+ sessions",
    "high_estimated_handicap": "Estimated handicap > 25",
    "user_short_game_request": "User explicitly asks about short game",
    "wedge_carry_std_gt12": "Wedge carry standard deviation > 12 yards",
    "ball_runs_out": "Total distance significantly exceeds carry (low stopping power)"
  }
